{
  "rules": [
    {
      "allowed": {
        "origins": ["*"],
        "methods": ["GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": [
        "ETag",
        "Content-Length",
        "Content-Type",
        "Accept-Ranges"
      ],
      "maxAgeSeconds": 86400
    }
  ]
}
