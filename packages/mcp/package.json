{
  "name": "woven-sfx-mcp",
  "version": "0.2.0",
  "description": "stdio MCP server for the Woven SFX catalog",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/woven-video/woven-sfx.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://sfx.woven.video",
  "bugs": "https://github.com/woven-video/woven-sfx/issues",
  "license": "MIT",
  "keywords": [
    "mcp",
    "sfx",
    "sound-effects",
    "woven",
    "agent"
  ],
  "bin": {
    "woven-sfx-mcp": "./dist/bundle.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bundle": "node scripts/build-bundle.mjs",
    "prepublishOnly": "pnpm --filter @woven-sfx/core build && pnpm build:bundle",
    "start": "node dist/index.js",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-alpha.3",
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@woven-sfx/core": "workspace:*",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0"
  },
  "files": [
    "dist/bundle.js",
    "dist/catalog.json",
    "catalog.json"
  ],
  "publishConfig": {
    "access": "public"
  }
}
