---
import catalog from "../../public/catalog.json";
---

<footer class="border-t border-stone-800">
  <div
    class="mx-auto flex max-w-6xl flex-col gap-2 px-4 py-8 text-sm text-stone-500 sm:flex-row sm:items-center sm:justify-between sm:px-6"
  >
    <p>
      <span class="text-stone-400">MIT</span> · <span class="text-stone-400"
        >CC0</span
      >
      sounds
    </p>
    <p class="flex flex-wrap items-center gap-x-3 gap-y-1">
      <a
        href="https://woven.video"
        target="_blank"
        rel="noopener noreferrer"
        class="text-stone-400 transition-colors hover:text-stone-200"
      >
        woven.video
      </a>
      <span aria-hidden="true" class="text-stone-600">·</span>
      <span>catalog v{catalog.version}</span>
    </p>
  </div>
</footer>