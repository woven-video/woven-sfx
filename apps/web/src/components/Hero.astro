---
import InstallPanel from "./InstallPanel";
---

<section id="install" class="border-b border-border/60">
  <div class="mx-auto max-w-6xl px-6 py-6 md:py-8">
    <div class="flex flex-col gap-5">
      <div class="max-w-3xl">
        <p class="font-mono text-base text-muted-foreground">woven-sfx</p>
        <h1
          class="mt-2 text-4xl font-semibold tracking-normal leading-[0.98] text-balance md:text-5xl lg:text-6xl"
        >
          Sound Effects Library for AI Agents
        </h1>
        <p
          id="summary"
          class="mt-4 max-w-[68rem] text-base leading-[1.45] text-muted-foreground md:text-lg"
        >
          Open source library of whooshes, pops, and glitches built for agent
          video edits. Install the skill and MCP server once. Your agent
          resolves and pulls the right .wav for every transition.
        </p>
      </div>

      <InstallPanel client:load />
    </div>
  </div>
</section>
