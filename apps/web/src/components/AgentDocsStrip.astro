---
const links = [
  {
    href: "/catalog.json",
    title: "catalog.json",
    description: "Machine-readable sound index with ids, tags, and URLs.",
  },
  {
    href: "/llms.txt",
    title: "llms.txt",
    description: "Agent-readable index of install, catalog, and MCP tools. Primary install: npx skills add.",
  },
  {
    href: "https://github.com/woven-video/woven-sfx",
    title: "GitHub",
    description: "Source code, catalog metadata, and MCP server.",
    external: true,
  },
  {
    href: "/install.sh",
    title: "install.sh",
    description: "Legacy curl installer — skill via skills CLI, library prefetch, MCP instructions.",
  },
];

const tools = [
  {
    name: "sfx_search",
    input: "{ tag?, transition?, query? }",
    description: "Search the catalog by tag, transition pairing, or query string.",
  },
  {
    name: "sfx_pull",
    input: "{ id }",
    description: "Download a sound by id to the project library (./sounds/sfx/ or project.md sfx-library).",
  },
  {
    name: "sfx_resolve",
    input: "{ transition, moment? }",
    description:
      "Resolve and pull the best sound for a video transition type.",
  },
  {
    name: "sfx_list_installed",
    input: "—",
    description: "List .wav files already cached in the local SFX library.",
  },
];
---

<section
  id="agents"
  class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16"
>
  <div class="mb-8 max-w-2xl">
    <p class="text-xs font-medium uppercase tracking-wider text-stone-500">
      For agents
    </p>
    <h2 class="mt-2 text-2xl font-semibold tracking-tight text-stone-200">
      Docs &amp; MCP tools
    </h2>
    <p class="mt-2 text-sm text-stone-400">
      Install with skills CLI, then point your agent at the catalog and stdio MCP server.
    </p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="group rounded-xl border border-stone-800 bg-stone-900/40 p-5 transition-colors hover:border-stone-700 hover:bg-stone-900/70"
          {...(link.external
            ? { target: "_blank", rel: "noopener noreferrer" }
            : {})}
        >
          <h3 class="font-mono text-sm font-medium text-stone-200 group-hover:text-white">
            {link.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-stone-400">
            {link.description}
          </p>
        </a>
      ))
    }
  </div>

  <div class="mt-10 rounded-xl border border-stone-800 bg-stone-900/40 p-5 sm:p-6">
    <p class="mb-6 text-xs font-medium uppercase tracking-wider text-stone-500">
      MCP tools
    </p>

    <ul class="space-y-5">
      {
        tools.map((tool) => (
          <li class="border-b border-stone-800 pb-5 last:border-b-0 last:pb-0">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <h3 class="font-mono text-sm font-medium text-stone-200">
                {tool.name}
              </h3>
              <span class="font-mono text-xs text-stone-500">{tool.input}</span>
            </div>
            <p class="mt-1.5 text-sm text-stone-400">{tool.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>